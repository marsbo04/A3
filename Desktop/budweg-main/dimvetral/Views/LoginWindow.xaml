<Window x:Class="dimvetral.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dimvetral"
        mc:Ignorable="d"
        Title="Login" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="White" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <!-- Main Container -->
        <Border BorderBrush="Black" BorderThickness="3" Margin="20" Padding="40">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <!-- Title -->
                <TextBlock Text="D.I.M.Ve.Tra.L." 
                           FontSize="36" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30"
                           Foreground="Black"/>

                <!-- Person/Contact Icon -->
                <Ellipse Width="100" Height="100" Stroke="Black" StrokeThickness="3"/>
                <Canvas Width="100" Height="100" Margin="0,-100,0,0">
                    <!-- Head -->
                    <Ellipse Width="30" Height="30" Stroke="Black" StrokeThickness="3" Canvas.Left="35" Canvas.Top="21" RenderTransformOrigin="0.522,0.517" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <!-- Shoulders -->
                    <Path Data="M 20,80 A 30,30 0 0 1 80,80" Stroke="Black" StrokeThickness="3" Canvas.Left="0" Canvas.Top="0"/>
                </Canvas>

                <!-- Login Label -->
                <TextBlock Text="login" 
                           FontSize="18" 
                           HorizontalAlignment="Center" 
                           Margin="0,30,0,10"
                           Foreground="Black"/>

                <!-- User ID Input Field -->
                <TextBox x:Name="UserIdTextBox"
                         Margin="0,0,0,15" 
                         Width="200" 
                         Height="35" 
                         VerticalContentAlignment="Center" 
                         HorizontalContentAlignment="Center" 
                         BorderBrush="Black" 
                         BorderThickness="2"
                         Foreground="Black"
                         GotFocus="UserIdTextBox_GotFocus"
                         LostFocus="UserIdTextBox_LostFocus"
                         Text="Indtast Bruger-ID..."/>

                <!-- Password Input Field -->
                <PasswordBox x:Name="PasswordBox"
                             Margin="0,0,0,20" 
                             Width="200" 
                             Height="35" 
                             VerticalContentAlignment="Center" 
                             HorizontalContentAlignment="Center" 
                             BorderBrush="Black" 
                             BorderThickness="2"
                             PasswordChar="●"
                             GotFocus="PasswordBox_GotFocus"
                             KeyDown="PasswordBox_KeyDown"/>

                <!-- Password Placeholder (shown when empty) -->
                <TextBlock x:Name="PasswordPlaceholder"
                           Text="Indtast Kodeord..."
                           IsHitTestVisible="False"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,-47,0,20"/>

                <!-- Error Message -->
                <TextBlock x:Name="ErrorMessageTextBlock"
                           Foreground="Red"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"
                           TextWrapping="Wrap"
                           Width="250"
                           TextAlignment="Center"
                           Visibility="Collapsed"/>

                <!-- Login Button -->
                <Button x:Name="LoginButton"
                        Content="Log ind" 
                        Width="200" 
                        Height="40"
                        FontSize="16"
                        Background="#2196F3"
                        Foreground="White"
                        BorderBrush="Black"
                        BorderThickness="2"
                        Cursor="Hand"
                        Click="LoginButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1976D2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>
