<Window x:Class="dimvetral.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dimvetral"
        mc:Ignorable="d"
        Title="Kaliber Følgeseddel System" Height="450" Width="800">
    <Grid Background="#F5F5F5">
        <!-- Hovedramme der tilpasser sig skærmen -->
        <Border BorderBrush="Black" BorderThickness="3" Margin="15" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Venstre side tager 65% af pladsen, højre tager 35% -->
                    <ColumnDefinition Width="6.5*" />
                    <ColumnDefinition Width="3.5*" />
                </Grid.ColumnDefinitions>

                <!-- VENSTRE SEKTION: Historik (Responsiv container) -->
                <Border BorderBrush="Black" BorderThickness="0,0,2,0">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="Kaliber følgeseddel / Historik" 
                                   FontWeight="Bold" 
                                   FontSize="20" 
                                   HorizontalAlignment="Left" 
                                   VerticalAlignment="Top"
                                   Margin="0,0,0,15" />

                        <!-- DataGrid bundet til TrackingHistory -->
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding TrackingHistory}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderBrush="Black"
                                  BorderThickness="1"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F9F9F9"
                                  CanUserResizeRows="False"
                                  CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Kaliber ID" 
                                                    Binding="{Binding CaliberTrackingSlipID}" 
                                                    Width="Auto" 
                                                    MinWidth="100" />
                                <DataGridTextColumn Header="Lokation" 
                                                    Binding="{Binding Location}" 
                                                    Width="*" 
                                                    MinWidth="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- HØJRE SEKTION: Kontrolpanel -->
                <Grid Grid.Column="1" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!-- Bruger info -->
                        <RowDefinition Height="*" />
                        <!-- Center ikon -->
                        <RowDefinition Height="Auto" />
                        <!-- Knapper i bunden -->
                    </Grid.RowDefinitions>

                    <!-- Top: ID Information -->
                    <StackPanel Grid.Row="0">
                        <!-- Medarbejder ID -->
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Medarbejder ( ID )" 
                                       VerticalAlignment="Center" 
                                       FontWeight="SemiBold" />
                            <Border Width="35" Height="35" 
                                    BorderBrush="Black" 
                                    BorderThickness="2" 
                                    CornerRadius="17.5"
                                    HorizontalAlignment="Right"
                                    Background="White">
                                <TextBlock Text="{Binding EmployeeId}" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis" />
                            </Border>
                        </Grid>
                        
                        <!-- Bremseskaliber ID -->
                        <Grid>
                            <TextBlock Text="Bremseskaliber ( ID )" 
                                       VerticalAlignment="Center" 
                                       FontWeight="SemiBold" />
                            <Border Width="35" Height="35" 
                                    BorderBrush="Black" 
                                    BorderThickness="2" 
                                    CornerRadius="17.5"
                                    HorizontalAlignment="Right"
                                    Background="White">
                                <TextBlock Text="{Binding CaliberId}" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis" />
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- Midte: Stort Responsivt Ikon -->
                    <Viewbox Grid.Row="1" MaxHeight="200" Margin="0,20">
                        <Grid Width="100" Height="100">
                            <Ellipse Stroke="Black" StrokeThickness="2" Fill="Transparent" />
                            <Path Data="M 30,35 L 50,25 L 70,35 L 70,60 L 50,70 L 30,60 Z M 30,35 L 50,45 L 70,35 M 50,45 L 50,70" 
                                  Stroke="Black" StrokeThickness="2" />
                        </Grid>
                    </Viewbox>

                    <!-- Bund: Aktioner -->
                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                        <!-- Knappen til at tilføje ny kaliber - BUNDET TIL COMMAND -->
                        <Button Content="Tilføj ny kaliber" 
                                Command="{Binding AddNewCaliberCommand}"
                                Padding="10"
                                FontSize="16"
                                FontWeight="Bold"
                                Background="White"
                                BorderBrush="Black"
                                BorderThickness="2"
                                HorizontalAlignment="Stretch"
                                Cursor="Hand"
                                Margin="0,0,0,15">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E0E0E0" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Log ud knap - BUNDET TIL COMMAND -->
                        <Button Content="Log ud" 
                                Command="{Binding LogoutCommand}"
                                Foreground="Red"
                                FontWeight="Bold"
                                Background="Transparent"
                                BorderThickness="0"
                                HorizontalAlignment="Center"
                                Padding="10"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="DarkRed" />
                                            <Setter Property="TextBlock.TextDecorations" Value="Underline" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
