<Window x:Class="dimvetral.Kaliber_IDInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dimvetral"
        mc:Ignorable="d"
        Title="Kaliber_IDInputWindow" Height="450" Width="800">
    <Grid Background="White" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <!-- Main Outer Border -->
        <Border BorderBrush="Black" BorderThickness="4" Margin="20" Padding="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Height="294" Width="354">
                <!-- Title -->
                <TextBlock Text="D.I.M.Ve.Tra.L." 
                           FontSize="36" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,0"
                           Foreground="Black"/>

                <!-- Box Icon inside a Circle -->
                <Grid Width="120" Height="110">
                    <Ellipse Stroke="Black" StrokeThickness="3" Margin="0,2,0,-2"/>
                    <!-- Simple Isometric Box Path -->
                    <Path Data="M 60,35 L 85,45 L 60,55 L 35,45 Z 
                            M 35,45 L 35,75 L 60,85 L 60,55
                            M 85,45 L 85,75 L 60,85
                            M 60,35 L 60,55" 
                          Stroke="Black" StrokeThickness="3" 
                          HorizontalAlignment="Center" VerticalAlignment="Center" Height="89" Stretch="Fill" Width="87"/>
                </Grid>
                <!-- text to input Kaliber-id-->
                <TextBlock Text="Intast Kaliber id" 
                           FontSize="18" 
                           HorizontalAlignment="Center" 
                           Margin="0,30,0,10"
                           Foreground="Black"/>
                <TextBox x:Name="CaliberIdTextBox"
                         Width="220" 
                         Height="60" 
                         Text="Indtast Kaliber-ID..." 
                         VerticalContentAlignment="Center" 
                         HorizontalContentAlignment="Center" 
                         BorderBrush="Black" 
                         BorderThickness="3"
                         FontWeight="Bold"
                         Foreground="Gray" 
                         TextChanged="TextBox_TextChanged"
                         GotFocus="TextBox_GotFocus"
                         LostFocus="TextBox_LostFocus"
                         KeyDown="TextBox_KeyDown"/>
                <!-- Input Field with Placeholder -->

            </StackPanel>
        </Border>
    </Grid>

</Window>
